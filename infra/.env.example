# Compose-level overrides. Defaults in docker-compose.yml are dev-safe.
# Copy to infra/.env if you want to change defaults locally.

POSTGRES_DB=product_catalog
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# Shared secret used by Laravel to call Next.js /api/revalidate.
# Set the same value here and in backend/.env as REVALIDATION_SECRET.
REVALIDATION_SECRET=dev-only-secret
